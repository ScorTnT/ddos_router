diff --git a/Dockerfile b/Dockerfile
--- a/Dockerfile	(revision 9636dbc0c289b5c7e3e1e12957e42cd207f4f094)
+++ b/Dockerfile	(date 1732065646749)
@@ -7,24 +7,51 @@
     musl-dev \
     git \
     make \
-    sqlite-dev
+    sqlite-dev \
+    libpcap-dev \
+    linux-headers \
+    build-base \
+    flex \
+    bison \
+    autoconf \
+    automake \
+    libtool
 
 # Set up Go environment for cross-compilation
 ENV GOARCH=arm64
 ENV GOOS=linux
 ENV CGO_ENABLED=1
-ENV CC=aarch64-linux-musl-gcc
 
-# Install aarch64 cross-compiler for SQLite
-RUN wget https://musl.cc/aarch64-linux-musl-cross.tgz \
-    && tar -xzf aarch64-linux-musl-cross.tgz \
-    && rm aarch64-linux-musl-cross.tgz \
+# Install cross-compiler
+RUN wget -q https://musl.cc/aarch64-linux-musl-cross.tgz \
+    && tar -xf aarch64-linux-musl-cross.tgz \
     && mv aarch64-linux-musl-cross /opt/cross
 
-# Set up the PATH to include the cross-compiler
+# Set environment variables for cross-compilation
 ENV PATH="/opt/cross/bin:${PATH}"
+ENV CC="/opt/cross/bin/aarch64-linux-musl-gcc"
+ENV CXX="/opt/cross/bin/aarch64-linux-musl-g++"
+ENV PKG_CONFIG_PATH="/opt/cross/aarch64-linux-musl/lib/pkgconfig"
+ENV CROSS_COMPILE="aarch64-linux-musl-"
 
-# Set the working directory in the container
+# Build and install libpcap for arm64
+RUN wget https://www.tcpdump.org/release/libpcap-1.10.4.tar.gz \
+    && tar -xzf libpcap-1.10.4.tar.gz \
+    && cd libpcap-1.10.4 \
+    && ac_cv_linux_vers=5 \
+    CC=${CC} \
+    CFLAGS="-Os -fPIC" \
+    LDFLAGS="-static" \
+    ./configure --host=aarch64-linux-musl \
+    --prefix=/opt/cross/aarch64-linux-musl \
+    --enable-static \
+    --disable-shared \
+    && make \
+    && make install \
+    && cd .. \
+    && rm -rf libpcap-1.10.4*
+
+# Set the working directory
 WORKDIR /app
 
 # Copy the Go modules manifests
@@ -37,7 +64,7 @@
 COPY . .
 
 # Build the application
-RUN CGO_ENABLED=1 GOOS=linux GOARCH=arm64 CC=aarch64-linux-musl-gcc \
+RUN CGO_ENABLED=1 GOOS=linux GOARCH=arm64 \
     go build -ldflags="-linkmode external -extldflags '-static'" -o /app/backend
 
 # Final stage
